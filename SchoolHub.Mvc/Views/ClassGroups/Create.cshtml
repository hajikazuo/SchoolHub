@model SchoolHub.Common.Models.Entities.ClassGroup

@{
    ViewData["Title"] = "Create";
    var availableUsers = ViewBag.AvailableUsers as IEnumerable<SchoolHub.Common.Models.Entities.Users.User>;
}

<h1>Create</h1>

<h4>ClassGroup</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label>Students</label>
                @foreach (var user in availableUsers)
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="selectedUserIds" value="@user.Id" />
                        <label class="form-check-label">@user.Name</label>
                    </div>
                }
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
